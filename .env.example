# --- Database (Vercel Postgres / Neon) ---
# Provisioned via Vercel dashboard: Storage -> Create Database -> Postgres.
# Vercel injects these automatically into the project once the DB is attached;
# for local dev, copy them from Vercel dashboard -> Settings -> Environment Variables.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# --- football-data.org ---
# Free tier API key: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# --- The Odds API ---
# Free tier API key (500 credits/month): https://the-odds-api.com/
ODDS_API_KEY=

# --- Cron security ---
# Random secret string; Vercel Cron sends it as a Bearer token so the
# /api/cron/update route can reject requests that don't come from Vercel Cron.
CRON_SECRET=
